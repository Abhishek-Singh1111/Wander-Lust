<% layout('layouts/boilerplate') %>
<div class="row mt-3">
  <div class="col-8 offset-2">
    <h2 style="font-weight: 600;">Edit Listing</h2>
    <form method="POST" action="/listings/<%= listing._id %>?_method=PUT" enctype="multipart/form-data" class="needs-validation" novalidate>
      <div class="mb-3">
        <label for="title" class="form-control"><b>Title</b></label>
        <input type="text" class="form-control" name="listing[title]" id="title" value="<%= listing.title %>" required>
        <div class="valid-feedback">Title looks good</div>
      </div>

      <div class="mb-3">
        <label for="description" class="form-control"><b>Description</b></label>
        <textarea name="listing[description]" id="description" placeholder="Write description" class="form-control" required><%= listing.description %></textarea>
        <div class="invalid-feedback">Please enter description</div>
      </div>

      <div class="mb-3">
        <label for="location" class="form-control"><b>Location:</b></label>
        <input type="text" name="listing[location]" id="location" placeholder="Enter location" class="form-control" value="<%= listing.location %>" required>
        <div class="invalid-feedback">Please enter a valid location</div>
      </div>

      <div class="row">
        <div class="mb-3 col-md-6">
          <label for="country" class="form-control"><b>Country</b></label>
          <input type="text" name="listing[country]" id="country" placeholder="Enter country" class="form-control" value="<%= listing.country %>" required>
          <div class="invalid-feedback">Please enter a valid country</div>
        </div>
        <div class="mb-3 col-md-6">
          <label for="price" class="form-control"><b>Enter price:</b></label>
          <input type="number" name="listing[price]" id="price" placeholder="Enter price in ₹" class="form-control" value="<%= listing.price %>" required>
          <div class="invalid-feedback">Please enter price</div>
        </div>
      </div>
  <h4>Current image</h4>
      <div class="card col-6 show-card listing-card">
  <img src="<%=listing.image.url%>" class="card-img-top show-img">
  </div>

      <div class="mb-3">
        <label for="image" class="form-control"><b> Uplode Image source </b></label>
        <input type="file" name="listing[image]" id="image" placeholder="uplode image" class="form-control">
      </div>
      <button class="btn btn-dark edit-btn">Edit</button>
      <br><br>
    </form>
  </div>
</div>